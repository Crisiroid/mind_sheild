# Application Configuration
APP_PORT=8080
APP_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=psychology_app
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# File Upload Configuration
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:8080

# Weekly Media Content Upload
# Admin can upload files (audio, video, document, image) for weekly content
# Max file size: 100MB
# Supported formats: mp3, wav, ogg, m4a, mp4, avi, mkv, pdf, doc, docx, jpg, png, etc.
# Files are stored in: ./uploads/weekly-media/
# Users can download and view content by week number
